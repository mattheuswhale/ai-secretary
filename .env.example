# ═══════════════════════════════════════════════════════════════════════
# Voice Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════

# ── Ollama ───────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=gemma4:e2b

# ── Whisper STT ──────────────────────────────────────────────────────────
# Model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# Inference device: cpu | cuda
WHISPER_DEVICE=cpu
# Quantization: int8 | float16 | float32
WHISPER_COMPUTE=int8

# ── VAD (Voice Activity Detection) ──────────────────────────────────────
SILENCE_THRESHOLD=0.015
SILENCE_SECONDS=1.5
MAX_RECORD_SECS=30
VAD_CALIBRATION_SECS=1.0
# Speech trigger = ambient_rms * VAD_SPEECH_MULTIPLIER (raise if too sensitive)
VAD_SPEECH_MULTIPLIER=3.0
# Minimum continuous speech duration before committing (seconds)
VAD_MIN_SPEECH_SECS=0.4

# ── Kokoro TTS ───────────────────────────────────────────────────────────
# Voice names per language — run `python -c "from kokoro import KPipeline; p=KPipeline('a'); print(list(p.voices))"` to list voices
KOKORO_VOICE_EN=af_heart
KOKORO_VOICE_JA=jf_alpha
KOKORO_VOICE_KO=kf_nayeon

# ── Default Location (weather fallback) ──────────────────────────────────
DEFAULT_LAT=51.4778
DEFAULT_LON=0.0015
DEFAULT_CITY=GREENWICH
